# Copy this file to `.env`:
#
#   cp .env.example .env
#
# You do NOT need a key. The default PROVIDER=mock runs the whole repo offline,
# deterministically, for $0 — the harness primitives (hooks, permission policies,
# sandboxing, subagents, headless runs) are all provider-neutral, so a mock model
# is all you need to see them work. Add a key only to watch the same harness drive
# a real model.
#
# NEVER commit your real .env file. It is already in .gitignore.

# ---------------------------------------------------------------------------
#   mock    -> a deterministic, offline, in-process "model"   (no key)   DEFAULT
#   openai  -> OpenAI chat + function calling                 (OPENAI_API_KEY)
#   claude  -> Claude messages + tool use                     (ANTHROPIC_API_KEY)
# ---------------------------------------------------------------------------
PROVIDER=mock

# --- API keys (optional) are NOT stored here ---
# The default mock needs no key. To use a real provider, store its key in your OS
# keychain and inject it per-command with `secrun` (setup: ../SECRETS.md), then run
# key-using scripts as:  secrun python examples/...
#   PROVIDER=openai  needs  OPENAI_API_KEY     https://platform.openai.com/api-keys
#   PROVIDER=claude  needs  ANTHROPIC_API_KEY  https://console.anthropic.com/settings/keys
